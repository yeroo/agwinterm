<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Agwinterm.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml">
    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" x:Name="Sidebar" Background="#0F1113">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="SidebarPanel" Spacing="1" Margin="2" />
            </ScrollViewer>
            <!-- Sidebar footer (agterm's bottom bar): new workspace, new session, flagged toggle -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="2" Padding="6,4" Background="#0B0D0F">
                <Button x:Name="NewWorkspaceButton" IsTabStop="False"
                        ToolTipService.ToolTip="New Workspace">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE8F4;" FontSize="14" />
                </Button>
                <Button x:Name="NewSessionButton" IsTabStop="False"
                        ToolTipService.ToolTip="New Session">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="14" />
                </Button>
                <Button x:Name="FlagButton" IsTabStop="False"
                        ToolTipService.ToolTip="Show flagged sessions">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE7C1;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <canvas:CanvasControl Grid.Column="1" x:Name="GridCanvas" Draw="OnDraw"
                              ClearColor="Black" IsTabStop="True" />
    </Grid>
</Window>
