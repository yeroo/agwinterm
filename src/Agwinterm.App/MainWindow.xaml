<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Agwinterm.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml">
    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#0F1113">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Button Grid.Row="0" x:Name="NewSessionButton" Margin="6" IsTabStop="False"
                    HorizontalAlignment="Stretch" Content="＋  New session" />
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="SidebarPanel" Spacing="2" Margin="4" />
            </ScrollViewer>
        </Grid>

        <canvas:CanvasControl Grid.Column="1" x:Name="GridCanvas" Draw="OnDraw"
                              ClearColor="Black" IsTabStop="True" />
    </Grid>
</Window>
